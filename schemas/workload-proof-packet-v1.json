{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cfregly/claude-gpu-perf-tune/schemas/workload-proof-packet-v1.json",
  "title": "Neocloud workload proof packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "status",
    "created_at_utc",
    "owner",
    "audience",
    "workload",
    "target",
    "stack",
    "run",
    "measurements",
    "baseline",
    "evidence",
    "gates",
    "verdict"
  ],
  "properties": {
    "schema_version": {
      "const": "workload_proof_packet_v1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "verdict"]
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model_id",
        "model_source",
        "dataset",
        "input_tokens",
        "output_tokens",
        "concurrency",
        "request_count",
        "success_criteria"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "model_source": {
          "type": "string",
          "minLength": 1
        },
        "dataset": {
          "type": "string",
          "minLength": 1
        },
        "input_tokens": {
          "type": "number",
          "minimum": 0
        },
        "output_tokens": {
          "type": "number",
          "minimum": 0
        },
        "concurrency": {
          "type": "number",
          "minimum": 0
        },
        "request_count": {
          "type": "number",
          "minimum": 0
        },
        "success_criteria": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "neocloud",
        "region",
        "zone",
        "gpu_sku",
        "gpu_count",
        "topology",
        "interconnect",
        "availability_source"
      ],
      "properties": {
        "neocloud": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "zone": {
          "type": "string",
          "minLength": 1
        },
        "gpu_sku": {
          "type": "string",
          "minLength": 1
        },
        "gpu_count": {
          "type": "number",
          "minimum": 0
        },
        "topology": {
          "type": "string",
          "minLength": 1
        },
        "interconnect": {
          "type": "string",
          "minLength": 1
        },
        "availability_source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container_image",
        "serving_engine",
        "engine_version",
        "cuda_version",
        "driver_version",
        "nccl_version",
        "launch_flags"
      ],
      "properties": {
        "container_image": {
          "type": "string",
          "minLength": 1
        },
        "serving_engine": {
          "type": "string",
          "minLength": 1
        },
        "engine_version": {
          "type": "string",
          "minLength": 1
        },
        "cuda_version": {
          "type": "string",
          "minLength": 1
        },
        "driver_version": {
          "type": "string",
          "minLength": 1
        },
        "nccl_version": {
          "type": "string",
          "minLength": 1
        },
        "launch_flags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "environment"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "cwd",
              "command",
              "stdout_path",
              "stderr_path",
              "exit_path",
              "exit_code"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "cwd": {
                "type": "string",
                "minLength": 1
              },
              "command": {
                "type": "string",
                "minLength": 1
              },
              "stdout_path": {
                "type": "string",
                "minLength": 1
              },
              "stderr_path": {
                "type": "string",
                "minLength": 1
              },
              "exit_path": {
                "type": "string",
                "minLength": 1
              },
              "exit_code": {
                "type": "integer"
              }
            }
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sanitized_env_path", "secrets_policy"],
          "properties": {
            "sanitized_env_path": {
              "type": "string",
              "minLength": 1
            },
            "secrets_policy": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latency", "throughput", "utilization", "cost", "reliability"],
      "properties": {
        "latency": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ms_p50", "ms_p95", "tpot_ms"],
          "properties": {
            "ms_p50": {
              "type": "number",
              "minimum": 0
            },
            "ms_p95": {
              "type": "number",
              "minimum": 0
            },
            "tpot_ms": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "throughput": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "output_tokens_per_second",
            "total_tokens_per_second",
            "tokens_per_second_per_gpu"
          ],
          "properties": {
            "output_tokens_per_second": {
              "type": "number",
              "minimum": 0
            },
            "total_tokens_per_second": {
              "type": "number",
              "minimum": 0
            },
            "tokens_per_second_per_gpu": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "utilization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gpu_sm_pct", "gpu_memory_pct", "power_watts"],
          "properties": {
            "gpu_sm_pct": {
              "type": "number",
              "minimum": 0
            },
            "gpu_memory_pct": {
              "type": "number",
              "minimum": 0
            },
            "power_watts": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "gpu_hour_usd",
            "tokens_per_dollar",
            "dollars_per_million_tokens"
          ],
          "properties": {
            "gpu_hour_usd": {
              "type": "number",
              "minimum": 0
            },
            "tokens_per_dollar": {
              "type": "number",
              "minimum": 0
            },
            "dollars_per_million_tokens": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "reliability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["success_rate", "error_count"],
          "properties": {
            "success_rate": {
              "type": "number",
              "minimum": 0
            },
            "error_count": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "source", "comparable", "measurements"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "comparable": {
          "type": "boolean"
        },
        "measurements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "latency_ms_p95",
            "throughput_tokens_per_second",
            "cost_dollars_per_million_tokens"
          ],
          "properties": {
            "latency_ms_p95": {
              "type": "number",
              "minimum": 0
            },
            "throughput_tokens_per_second": {
              "type": "number",
              "minimum": 0
            },
            "cost_dollars_per_million_tokens": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_outputs",
        "logs",
        "profiler_traces",
        "normalized_summary_path",
        "source_repo",
        "source_commit",
        "source_dirty"
      ],
      "properties": {
        "raw_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "logs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "profiler_traces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "normalized_summary_path": {
          "type": "string",
          "minLength": 1
        },
        "source_repo": {
          "type": "string",
          "minLength": 1
        },
        "source_commit": {
          "type": "string",
          "minLength": 1
        },
        "source_dirty": {
          "type": "boolean"
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "passed",
          "required_for_verdict",
          "evidence_path"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "required_for_verdict": {
            "type": "boolean"
          },
          "evidence_path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "proof_scope",
        "not_proven",
        "caveats",
        "next_lever"
      ],
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "proof_scope": {
          "type": "string",
          "minLength": 1
        },
        "not_proven": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "caveats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_lever": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflow_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "attachment_role",
        "integration_id",
        "workflow_name",
        "current_access_stage",
        "target_access_stage",
        "packet_proves",
        "workflow_system_proves",
        "not_proven",
        "handoff_notes"
      ],
      "properties": {
        "schema_version": {
          "const": "workflow_handoff_v1"
        },
        "attachment_role": {
          "const": "workload_level_evidence"
        },
        "integration_id": {
          "type": "string",
          "minLength": 1
        },
        "workflow_name": {
          "type": "string",
          "minLength": 1
        },
        "current_access_stage": {
          "enum": ["offline", "shadow", "supervised_pilot", "default"]
        },
        "target_access_stage": {
          "enum": ["offline", "shadow", "supervised_pilot", "default"]
        },
        "packet_proves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "workflow_system_proves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "not_proven": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "handoff_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
